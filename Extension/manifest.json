{
  "manifest_version": 3,
  "name": "Local Vault Capture",
  "version": "2.0",
  "description": "Records AI chats procedurally to a local LLM bridge.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "downloads"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture Note"
  },
  "options_page": "options.html"
}